# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Database files (never commit live data) ───────────────────────────────────
Database/analytics.db
Database/seasons/
Database/export.json
Database/insert_batches.json
Database/*.sql
# Keep template and schema — they ARE committed
!Database/schema.sql
!Database/supabase_schema.sql
!Database/seasons.template.json

# ── Secrets & credentials ─────────────────────────────────────────────────────
Database/seasons.json
.streamlit/secrets.toml
*.env
.env
secrets.json

# ── Claude Code session files ─────────────────────────────────────────────────
.claude/

# ── Temp / export text files ──────────────────────────────────────────────────
*.txt
Database/*.txt
Database/*.tmp
Database/*.tmp.*
Database/db.py.tmp.*

# ── OS / editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
*.bak
.idea/
.vscode/settings.json

# ── Streamlit cache ───────────────────────────────────────────────────────────
.streamlit/cache/
