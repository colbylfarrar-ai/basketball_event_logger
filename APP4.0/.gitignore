# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# SQLite journal/temp files — never commit these
*.db-journal
*.db-wal
*.db-shm

# Ignore all .db files EXCEPT the main analytics database. We ship that one to
# Streamlit Cloud as a read-only data mirror: author data locally, then commit
# and push the updated analytics.db to refresh the deployed site.
*.db
!database/analytics.db

# Season config (machine-local season → db-file mapping)
database/seasons.json

# Streamlit secrets / local config
.streamlit/secrets.toml

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
