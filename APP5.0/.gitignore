# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Streamlit secrets (never commit credentials)
.streamlit/secrets.toml

# Logs / temp
*.log
*.tmp

# SQLite data — NEVER commit. The live DB lives outside the repo (%LOCALAPPDATA%\APP5
# or $APP5_DATA_DIR); a committed copy is stale, leaks real data to anyone with repo
# access, and — via db._migrate_legacy_db — would seed a fresh server from STALE data
# on first boot. Deploys carry data by scp'ing the real DB to the data dir (see DEPLOY.md).
database/*.db
database/*.db-wal
database/*.db-shm
*.db-wal
*.db-shm

# Claude Code local config (machine-specific paths)
.claude/

# OSSAA importer local HTML cache (Phase 1)
tools/.ossaa_cache/
