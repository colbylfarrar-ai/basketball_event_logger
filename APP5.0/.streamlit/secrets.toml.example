# Copy this file to .streamlit/secrets.toml (which is gitignored) and fill in
# real values to turn ON the login gate. Without a secrets.toml [auth] block
# the app runs open — fine locally, never expose it that way.
# Full walkthrough: AUTH_SETUP.md in the repo root.

[auth]
# Where Google sends users back after sign-in. Streamlit sends THIS exact value
# to Google (it is NOT derived from the request host), and it must EXACTLY match
# an "Authorized redirect URI" on the Google OAuth client.
#   local:    http://localhost:8501/oauth2callback
#   deployed: https://app.your-domain/oauth2callback
# CHANGE FOR PRODUCTION: the localhost default below WILL break hosted login
#   (Google -> redirect_uri_mismatch / bounce to a dead localhost). Change it to
#   your https app URL AND add that URL in the Google console (keep localhost for dev).
redirect_uri = "http://localhost:8501/oauth2callback"

# Any long random string — signs the identity cookie. Generate one:
#   python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "REPLACE-WITH-LONG-RANDOM-STRING"

# From Google Cloud Console -> APIs & Services -> Credentials
client_id = "1234567890-xxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxx"

server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
